#!/bin/bash
set -euo pipefail

# Resolve project root relative to the launcher location:
# <project>/Cortana.app/Contents/MacOS/launcher -> <project>
PROJECT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

osascript -e "tell application \"Terminal\" to activate" \
          -e "tell application \"Terminal\" to do script \"cd \\\"$PROJECT_DIR/cli\\\" && go run .\""
