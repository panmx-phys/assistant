#!/bin/bash
set -euo pipefail

# Resolve project root relative to the launcher location:
# <project>/Cortana.app/Contents/MacOS/launcher -> <project>
PROJECT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

DESKTOP_DIR="$PROJECT_DIR/desktop"
BIN_PATH="$DESKTOP_DIR/cortana-desktop"
LOG_DIR="$PROJECT_DIR/data/logs"
LOG_FILE="$LOG_DIR/desktop-launcher.log"
VENV_DIR="$PROJECT_DIR/.venv"
PY_BIN="$VENV_DIR/bin/python"

mkdir -p "$LOG_DIR"

# Ensure Python dependencies exist in a project-local virtualenv.
if [[ ! -x "$PY_BIN" ]]; then
  python3 -m venv "$VENV_DIR" >>"$LOG_FILE" 2>&1 || {
    osascript -e 'display dialog "Failed to create Python virtualenv for Cortana." buttons {"OK"} default button "OK" with icon stop'
    exit 1
  }
fi

if ! "$PY_BIN" -c "import fastapi, numpy" >/dev/null 2>&1; then
  "$PY_BIN" -m pip install --upgrade pip >>"$LOG_FILE" 2>&1
  "$PY_BIN" -m pip install -r "$PROJECT_DIR/requirements.txt" >>"$LOG_FILE" 2>&1 || {
    osascript -e 'display dialog "Failed to install Python dependencies. See data/logs/desktop-launcher.log" buttons {"OK"} default button "OK" with icon stop'
    exit 1
  }
fi

export CORTANA_PYTHON="$PY_BIN"

if [[ ! -x "$BIN_PATH" ]]; then
  (
    cd "$DESKTOP_DIR"
    go build -o cortana-desktop .
  ) >>"$LOG_FILE" 2>&1 || {
    osascript -e 'display dialog "Cortana desktop build failed. See data/logs/desktop-launcher.log" buttons {"OK"} default button "OK" with icon stop'
    exit 1
  }
fi

exec "$BIN_PATH" >>"$LOG_FILE" 2>&1
